# AntiScam backend-only environment variables.
# Copy to backend/.env for local development. Do NOT commit real secrets.
# On Vercel, configure these in Project Settings > Environment Variables.

# MongoDB Atlas
MONGODB_URI=
MONGODB_DB=
MONGODB_TIMEOUT_MS=5000
MONGODB_MAX_POOL_SIZE=10

# JWT auth used by legacy backend endpoints
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# Threat intelligence API keys (optional free/free-tier providers)
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
GOOGLE_SAFE_BROWSING_KEY=
OTX_API_KEY=
THREATFOX_API_KEY=

# Optional image/OCR backend integration
IMAGE_SCANNER_URL=

# Set false to disable external API request/response audit logs
ANTISCAM_AUDIT_LOG=true
